# ══════════════════════════════════════════════════════
#   CV Matcher — Configuration du moteur IA
# ══════════════════════════════════════════════════════

# ── OPTION A : Ollama (100% local, recommandé) ────────
# Installez Ollama sur https://ollama.com
# Puis dans un terminal : ollama pull gemma3:4b
AI_PROVIDER=ollama
API_KEY=ollama
API_BASE_URL=http://localhost:11434/v1
AI_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434

# Autres modèles Ollama disponibles :
#   AI_MODEL=llama3.2         (Meta, rapide)
#   AI_MODEL=llama3.1:8b      (Meta, plus précis)
#   AI_MODEL=mistral           (Mistral AI)
#   AI_MODEL=phi4:14b          (Microsoft)
#   AI_MODEL=qwen2.5:7b        (Alibaba)
#   AI_MODEL=deepseek-r1:8b   (DeepSeek local)
#   AI_MODEL=gemma3:12b        (Google, plus précis)

# ── OPTION B : Groq (cloud, gratuit) ─────────────────
# Clé sur : https://console.groq.com/keys
# AI_PROVIDER=groq
# API_KEY=gsk_votre_cle_ici
# API_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

# ── OPTION C : DeepSeek (cloud) ──────────────────────
# Clé sur : https://platform.deepseek.com
# AI_PROVIDER=deepseek
# API_KEY=sk_votre_cle_ici
# API_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# ── Stockage (optionnel) ─────────────────────────────
# DATABASE_URL=sqlite:///./cv_matcher.db
# UPLOAD_DIR=uploads

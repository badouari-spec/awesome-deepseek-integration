        'starlette.staticfiles',
        'starlette.responses',
        'anyio',
        'anyio._backends._asyncio',
        'anyio.from_thread',
        # ── Parsers de documents ──
        'pdfplumber',
        'pdfminer',
        'pdfminer.high_level',
        'pdfminer.layout',
        'pdfminer.pdftypes',
        'pdfminer.pdfpage',
        'pdfminer.pdfinterp',
